# ChemHeaven Configuration

# Oxo Pay / OxaPay API Credentials
# Set to 'sandbox' to use the local interactive simulator, or provide your merchant key
OXOPAY_MERCHANT_KEY=sandbox

# URLs for checkout callback and redirect return
OXOPAY_CALLBACK_URL=http://localhost:8000/checkout/payment-callback
OXOPAY_RETURN_URL=http://localhost:8000/checkout/payment-return
